<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F2041">

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#FFC857"/>

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#2A2B4A"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <TextView
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="←"
                android:textSize="24sp"
                android:textColor="@android:color/white"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lighter Details"
                android:textColor="#FFC857"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"/>

            <TextView
                android:id="@+id/favoriteButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="☆"
                android:textSize="24sp"
                android:textColor="#FFC857"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/editButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="✏️"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Main Image -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:background="#2A2B4A">

                    <ImageView
                        android:id="@+id/mainImageView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_camera"
                        android:scaleType="centerCrop"
                        android:padding="2dp"/>

                    <Button
                        android:id="@+id/addPhotoButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="16dp"
                        android:text="📷 Add Photo"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#EF3E36"
                        android:paddingHorizontal="16dp"/>
                </FrameLayout>

                <!-- Image Gallery (Horizontal Scroll) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/imageGalleryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="#2A2B4A"
                    android:padding="8dp"
                    android:clipToPadding="false"/>

                <!-- Lighter Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/lighterNameText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Lighter Name"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/ownerNameText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Owner: Loading..."
                        android:textColor="#FFC857"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textColor="#FFC857"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/lighterDescriptionText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No description"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.2"
                        android:layout_marginBottom="16dp"/>

                    <!-- Transfer Ownership Button (for owners only) -->
                    <Button
                        android:id="@+id/transferOwnershipButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔄 Transfer Ownership"
                        android:textColor="#1F2041"
                        android:backgroundTint="#FFC857"
                        android:layout_marginBottom="20dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2B4A"/>

                <!-- Comments Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/commentsCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Comments"
                        android:textColor="#FFC857"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Add Comment -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/commentEditText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Add a comment..."
                            android:textColorHint="#888888"
                            android:textColor="@android:color/white"
                            android:background="@drawable/rounded_background"
                            android:padding="12dp"
                            android:maxLines="3"
                            android:layout_marginEnd="8dp"/>

                        <Button
                            android:id="@+id/postCommentButton"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Post"
                            android:textColor="@android:color/white"
                            android:backgroundTint="#EF3E36"/>
                    </LinearLayout>

                    <!-- Comments List -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/commentsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>