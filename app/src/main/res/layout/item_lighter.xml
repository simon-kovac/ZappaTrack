<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Admin Badge (shown only for admins) -->
    <TextView
        android:id="@+id/adminBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADMIN VIEW"
        android:textSize="10sp"
        android:textColor="@android:color/holo_red_dark"
        android:background="#22FF0000"
        android:padding="4dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"/>

    <!-- Main content container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Lighter info section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Lighter name -->
            <TextView
                android:id="@+id/lighterNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lighter Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"/>

            <!-- Lighter description -->
            <TextView
                android:id="@+id/lighterDescriptionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginTop="2dp"/>

            <!-- Owner info (shown only for admins) -->
            <TextView
                android:id="@+id/lighterOwnerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Owner: "
                android:textSize="12sp"
                android:textColor="@android:color/holo_blue_dark"
                android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Action buttons container -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_vertical">

            <!-- Edit button -->
            <ImageButton
                android:id="@+id/editButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Edit"
                android:visibility="gone"
                android:layout_marginEnd="8dp"/>

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/deleteButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"
        android:alpha="0.2"
        android:layout_marginTop="12dp"/>

</LinearLayout>