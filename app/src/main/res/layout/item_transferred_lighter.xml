<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:minHeight="72dp">

    <!-- Rank Badge -->
    <TextView
        android:id="@+id/rankText"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="#1"
        android:textColor="#FFC857"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <!-- Ikonka zapalovače -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/lighterImageView"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:src="@android:drawable/ic_menu_camera"
        android:scaleType="center"
        android:background="#3A3B5A"
        app:shapeAppearanceOverlay="@style/CircularImageView"
        app:strokeColor="#FFC857"
        app:strokeWidth="1dp"/>

    <!-- Lighter Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/lighterNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lighter Name"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/currentOwnerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Owner: Username"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Transfer Count -->
    <TextView
        android:id="@+id/transferCountText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5 transfers"
        android:textColor="#FFC857"
        android:textSize="14sp"
        android:textStyle="bold"/>

</LinearLayout>