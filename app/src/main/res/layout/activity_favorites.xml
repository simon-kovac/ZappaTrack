<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F2041">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#FFC857"/>

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#2A2B4A"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="←"
                android:textSize="24sp"
                android:textColor="@android:color/white"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Friends &amp; Favorites"
                android:textColor="#FFC857"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"/>
        </LinearLayout>

        <!-- Tab Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#2A2B4A">

            <Button
                android:id="@+id/friendsTabButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="⭐ Friends"
                android:textColor="#1F2041"
                android:backgroundTint="#FFC857"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/lightersTabButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔥 Lighters"
                android:textColor="@android:color/white"
                android:backgroundTint="#4A4B6A"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Friends Section -->
        <LinearLayout
            android:id="@+id/friendsSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/friendsCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Friends"
                android:textColor="#FFC857"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/friendsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/noFriendsText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="No friends yet\n\nVisit user profiles and tap ⭐ to add friends!"
                android:textColor="#888888"
                android:textSize="16sp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Favorite Lighters Section -->
        <LinearLayout
            android:id="@+id/lightersSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/lightersCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Favorite Lighters"
                android:textColor="#FFC857"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lightersRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/noLightersText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="No favorite lighters yet\n\nVisit lighter details and tap ⭐ to add favorites!"
                android:textColor="#888888"
                android:textSize="16sp"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>